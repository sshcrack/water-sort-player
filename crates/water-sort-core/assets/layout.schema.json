{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/sshcrack/water-sort-player/crates/water-sort-core/assets/layout.schema.json",
    "title": "Water Sort Layout Definitions",
    "type": "array",
    "minItems": 1,
    "items": {
        "type": "object",
        "required": ["friendly-name", "layer", "rows"],
        "additionalProperties": false,
        "properties": {
            "friendly-name": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$"
            },
            "layer": {
                "type": "object",
                "required": ["spacing", "count"],
                "additionalProperties": false,
                "properties": {
                    "spacing": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "count": {
                        "type": "integer",
                        "minimum": 1
                    }
                }
            },
            "rows": {
                "type": "array",
                "minItems": 1,
                "items": {
                    "type": "object",
                    "required": ["start_position", "spacing", "bottle_count"],
                    "additionalProperties": false,
                    "properties": {
                        "start_position": {
                            "type": "array",
                            "minItems": 2,
                            "maxItems": 2,
                            "items": {
                                "type": "integer"
                            }
                        },
                        "spacing": {
                            "type": "array",
                            "minItems": 2,
                            "maxItems": 2,
                            "items": {
                                "type": "integer"
                            }
                        },
                        "bottle_count": {
                            "type": "integer",
                            "minimum": 1
                        }
                    }
                }
            }
        }
    }
}