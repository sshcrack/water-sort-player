{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build with cargo",
            "type": "shell",
            "command": "cargo build --workspace",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$rustc"
            ]
        },
        {
            "label": "Test with cargo nextest",
            "type": "shell",
            "command": "cargo nextest r -r --workspace",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [
                "$rustc"
            ]
        }
    ]
}